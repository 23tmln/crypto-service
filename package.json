  "version": "1.0.0",
  "description": "Signal-based crypto microservice for chat project",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "demo": "ts-node-dev --transpile-only src/demo.ts",
    "signal:test": "ts-node-dev --transpile-only src/testSignal.ts",
