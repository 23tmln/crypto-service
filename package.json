    "keys:test": "ts-node-dev --transpile-only src/testRealKeys.ts",
    "signal:stores": "ts-node-dev --transpile-only src/testSignalStores.ts",
    "signal:pq": "ts-node-dev --transpile-only src/testSignalPQ.ts",
    "signal:kem": "ts-node-dev --transpile-only src/testSignalKEM.ts",
    "bundle:test": "ts-node-dev --transpile-only src/testBundle.ts",
    "test:api": "ts-node-dev --transpile-only src/demoApi.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@signalapp/libsignal-client": "^0.88.1",
